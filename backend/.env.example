# Environment Variables for Modology Cabinet Designer

# ============================================
# DATABASE
# ============================================
DATABASE_URL=postgresql://user:password@localhost:5432/modology

# ============================================
# STRIPE (Payment Processing)
# ============================================
# Your Stripe Secret Key (from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key_here

# Stripe Webhook Secret (from https://dashboard.stripe.com/webhooks)
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx

# Stripe Price IDs (created by running /api/stripe/create-products)
STRIPE_PRICE_HOBBYIST=price_xxxxxxxxxxxxx
STRIPE_PRICE_PRO=price_xxxxxxxxxxxxx
STRIPE_PRICE_SHOP=price_xxxxxxxxxxxxx

# ============================================
# FRONTEND (Public - exposed to browser)
# ============================================
NEXT_PUBLIC_STRIPE_PRICE_HOBBYIST=price_xxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PRICE_PRO=price_xxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PRICE_SHOP=price_xxxxxxxxxxxxx
NEXT_PUBLIC_API_URL=http://localhost:8000

# ============================================
# JWT AUTHENTICATION
# ============================================
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ============================================
# LLM/AI (Optional - for chat assistant)
# ============================================
OPENAI_API_KEY=sk-xxxxxxxxxxxxx
# or
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx

# ============================================
# EMAIL (Optional - for notifications)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# ============================================
# DEPLOYMENT
# ============================================
# Fly.io (backend)
FLY_API_TOKEN=xxxxxxxxxxxxx

# Vercel (frontend)
VERCEL_TOKEN=xxxxxxxxxxxxx
