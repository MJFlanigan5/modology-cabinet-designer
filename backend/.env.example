# ============================================
# ENVIRONMENT VARIABLES FOR KERFOS
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ============================================
# APPLICATION
# ============================================
APP_NAME=KerfOS
APP_ENV=development
APP_URL=https://kerfos.com
APP_PORT=8000

# ============================================
# DATABASE
# ============================================
DATABASE_URL=postgresql://user:password@localhost:5432/kerfos
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ============================================
# AUTHENTICATION & SECURITY
# ============================================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your-jwt-secret-key-here-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# CSRF Protection
CSRF_SECRET_KEY=your-csrf-secret-key-here-min-32-chars

# Session Management
SESSION_SECRET_KEY=your-session-secret-key-here-min-32-chars
SESSION_TIMEOUT_HOURS=24
MAX_SESSIONS_PER_USER=5

# ============================================
# STRIPE (Payments)
# ============================================
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Pricing
STRIPE_MONTHLY_PRICE_ID=price_monthly
STRIPE_ANNUAL_PRICE_ID=price_annual

# ============================================
# CORS
# ============================================
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:4173,https://kerfos.com,https://www.kerfos.com

# ============================================
# SECURITY HEADERS
# ============================================
# Set to 'strict' in production
HSTS_MAX_AGE=31536000
CONTENT_SECURITY_POLICY=default-src 'self'; script-src 'self' 'unsafe-inline' https://js.stripe.com;

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
RATE_LIMIT_AUTH_REQUESTS=10
RATE_LIMIT_AUTH_WINDOW=60

# ============================================
# FILE STORAGE
# ============================================
# For local development
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760

# For cloud storage (optional)
# AWS_ACCESS_KEY_ID=your-aws-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret
# AWS_S3_BUCKET=kerfos-uploads
# AWS_REGION=us-east-1

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# External logging (optional)
# DATADOG_API_KEY=your-datadog-key
# LOGFLARE_SOURCE_TOKEN=your-logflare-token

# ============================================
# MONITORING
# ============================================
# Sentry (optional)
# SENTRY_DSN=https://xxx@sentry.io/xxx

# ============================================
# EMAIL (for notifications)
# ============================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@kerfos.com
SMTP_PASSWORD=your-smtp-password
EMAIL_FROM=noreply@kerfos.com

# ============================================
# GDPR COMPLIANCE
# ============================================
PRIVACY_EMAIL=privacy@kerfos.com
DPO_EMAIL=dpo@kerfos.com
SECURITY_EMAIL=security@kerfos.com

# ============================================
# INTEGRATIONS (Optional)
# ============================================
# Google Analytics (with user consent)
# GA_TRACKING_ID=UA-XXXXXXXXX-X

# Home Depot API (for price feeds)
# HOMEDEPOT_API_KEY=your-homedepot-key

# Lowe's API (for price feeds)
# LOWES_API_KEY=your-lowes-key

# ============================================
# DEVELOPMENT ONLY
# ============================================
# Set to true to enable debug mode (NEVER in production!)
DEBUG=false

# Set to true to enable API docs at /docs
ENABLE_DOCS=true
